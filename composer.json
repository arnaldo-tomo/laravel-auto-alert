{
    "name": "arnaldo-tomo/laravel-auto-alert",
    "description": "Zero-configuration notification package for Laravel that automatically detects session flash messages, validation errors, HTTP errors, and DELETE form submissions.",
    "type": "library",
    "authors": [
        {
            "name": "Arnaldo Tomo",
            "homepage": "https://github.com/arnaldo-tomo",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/contracts": "^10.0|^11.0",
        "illuminate/session": "^10.0|^11.0",
        "illuminate/routing": "^10.0|^11.0",
        "illuminate/view": "^10.0|^11.0",
        "illuminate/console": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "ArnaldoTomo\\AutoAlert\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "ArnaldoTomo\\AutoAlert\\AutoAlertServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable"
}
